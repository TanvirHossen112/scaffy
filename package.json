{
  "name": "scaffy-tool",
  "type": "module",
  "version": "1.0.1",
  "description": "One command. Any framework. Ready to code.",
  "author": "Md Tanvir Hossen <tanvirhossen112@gmail.com>",
  "license": "MIT",
  "main": "cli.js",
  "bin": {
    "scaffy": "cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "scaffolding",
    "cli",
    "laravel",
    "nestjs",
    "vuejs",
    "django",
    "framework",
    "generator",
    "boilerplate",
    "project-setup"
  ],
  "files": [
    "cli.js",
    "core/",
    "registry/",
    "!core/tests/",
    "!registry/**/tests/"
  ],
  "homepage": "https://github.com/TanvirHossen112/scaffy",
  "bugs": {
    "url": "https://github.com/TanvirHossen112/scaffy/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TanvirHossen112/scaffy.git"
  },
  "scripts": {
    "start": "node cli.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:ci": "node --experimental-vm-modules node_modules/.bin/jest --coverage --ci --runInBand",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^11.1.0",
    "figlet": "^1.10.0",
    "inquirer": "^13.3.2",
    "ora": "^9.3.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-node": "^11.1.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "!(jest.config).js": [
      "eslint --fix",
      "prettier --write",
      "node --experimental-vm-modules node_modules/.bin/jest --bail --findRelatedTests"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
