{
  "name": "scaffy",
  "type": "commonjs",
  "version": "0.1.0",
  "description": "One command. Any framework. Ready to code.",
  "author": "Md Tanvir Hossen <tanvirhossen112@gmail.com>",
  "license": "MIT",
  "main": "cli.js",
  "bin": {
    "scaffy": "./cli.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "scaffolding",
    "cli",
    "laravel",
    "nestjs",
    "vuejs",
    "django",
    "framework",
    "generator",
    "boilerplate",
    "project-setup"
  ],
  "files": [
    "cli.js",
    "core/",
    "registry/",
    "!core/tests/",
    "!registry/**/tests/"
  ],
  "homepage": "https://github.com/TanvirHossen112/scaffy",
  "bugs": {
    "url": "https://github.com/TanvirHossen112/scaffy/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TanvirHossen112/scaffy.git"
  },
  "scripts": {
    "start": "node cli.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci --runInBand",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "figlet": "^1.10.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-node": "^11.1.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "!(jest.config).js": [
      "eslint --fix",
      "prettier --write",
      "jest --bail --findRelatedTests"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
